#!/usr/bin/env python3
"""claude-pilot CLI 管理工具。"""
from __future__ import annotations
import argparse
import os
import signal
import subprocess
import sys

BASE_DIR = os.environ.get("CLAUDE_PILOT_DIR", os.path.expanduser("~/.claude-pilot"))
PLIST_LABEL = "com.claude-pilot"
PLIST_PATH = os.path.expanduser(f"~/Library/LaunchAgents/{PLIST_LABEL}.plist")
PID_PATH = os.path.join(BASE_DIR, ".pid")
LOG_PATH = os.path.join(BASE_DIR, "bot.log")


def _read_pid() -> int | None:
    try:
        with open(PID_PATH) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError):
        return None


def _check_pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def cmd_start(args: argparse.Namespace) -> None:
    pid = _read_pid()
    if pid and _check_pid_alive(pid):
        print(f"已在运行 (PID: {pid})")
        return
    # 清理残留的 tmux session（可能已死）
    subprocess.run(["tmux", "kill-session", "-t", "claude-pilot"],
                   capture_output=True, check=False)
    bot_py = os.path.join(BASE_DIR, "bot.py")
    python = os.path.join(BASE_DIR, ".venv", "bin", "python3")
    subprocess.run(
        ["tmux", "new-session", "-d", "-s", "claude-pilot",
         f"{python} {bot_py} >> {LOG_PATH} 2>&1"],
        check=False,
    )
    print("已启动")


def cmd_stop(args: argparse.Namespace) -> None:
    pid = _read_pid()
    if not pid:
        print("未运行")
        return
    try:
        os.kill(pid, signal.SIGTERM)
        print(f"已发送停止信号 (PID: {pid})")
    except OSError:
        print("进程不存在")


def cmd_status(args: argparse.Namespace) -> None:
    pid = _read_pid()
    if pid and _check_pid_alive(pid):
        print(f"运行中 (PID: {pid})")
    else:
        print("未运行")


def cmd_enable(args: argparse.Namespace) -> None:
    bot_py = os.path.join(BASE_DIR, "bot.py")
    python = os.path.join(BASE_DIR, ".venv", "bin", "python3")
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" \
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>{python}</string>
        <string>{bot_py}</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>{LOG_PATH}</string>
    <key>StandardErrorPath</key>
    <string>{LOG_PATH}</string>
</dict>
</plist>"""
    os.makedirs(os.path.dirname(PLIST_PATH), exist_ok=True)
    with open(PLIST_PATH, "w") as f:
        f.write(plist)
    subprocess.run(["launchctl", "load", PLIST_PATH], check=False)
    print("已启用 launchd 自动启动")


def cmd_disable(args: argparse.Namespace) -> None:
    if os.path.exists(PLIST_PATH):
        subprocess.run(["launchctl", "unload", PLIST_PATH], check=False)
        os.unlink(PLIST_PATH)
        print("已禁用 launchd 自动启动")
    else:
        print("未启用")


def cmd_logs(args: argparse.Namespace) -> None:
    os.execvp("tail", ["tail", "-f", LOG_PATH])


def _remove_pilot_hooks(settings_file: str) -> None:
    """从 settings.json 中移除 claude-pilot 相关 hooks。"""
    import json
    try:
        with open(settings_file, "r", encoding="utf-8") as f:
            settings = json.load(f)
    except (json.JSONDecodeError, OSError):
        return
    if "hooks" not in settings:
        return
    marker = os.path.join(BASE_DIR, "hooks")
    for name in list(settings["hooks"]):
        cleaned = [e for e in settings["hooks"][name]
                   if not any(marker in h.get("command", "") for h in e.get("hooks", []))]
        if cleaned:
            settings["hooks"][name] = cleaned
        else:
            del settings["hooks"][name]
    if not settings.get("hooks"):
        settings.pop("hooks", None)
    with open(settings_file, "w", encoding="utf-8") as f:
        json.dump(settings, f, indent=2, ensure_ascii=False)
    print("已从 Claude Code 设置中移除 claude-pilot hooks")


def cmd_uninstall(args: argparse.Namespace) -> None:
    import shutil
    pid = _read_pid()
    if pid and _check_pid_alive(pid):
        try:
            os.kill(pid, signal.SIGTERM)
            print(f"已停止 Bot (PID: {pid})")
        except OSError:
            pass
    if os.path.exists(PLIST_PATH):
        subprocess.run(["launchctl", "unload", PLIST_PATH], capture_output=True, check=False)
        os.unlink(PLIST_PATH)
        print("已禁用 launchd 自动启动")
    subprocess.run(["tmux", "kill-session", "-t", "claude-pilot"], capture_output=True, check=False)
    settings_file = os.path.expanduser("~/.claude/settings.json")
    backup_file = os.path.join(BASE_DIR, "settings.json.backup")
    if os.path.exists(backup_file):
        shutil.copy2(backup_file, settings_file)
        print(f"已从备份恢复 Claude Code 设置: {backup_file} -> {settings_file}")
    elif os.path.exists(settings_file):
        _remove_pilot_hooks(settings_file)
    for bin_path in ["/usr/local/bin/claude-pilot", os.path.expanduser("~/.local/bin/claude-pilot")]:
        if os.path.exists(bin_path):
            try:
                os.unlink(bin_path)
                print(f"已删除 CLI: {bin_path}")
            except OSError as e:
                print(f"无法删除 {bin_path}: {e}")
    if os.path.exists(BASE_DIR):
        shutil.rmtree(BASE_DIR)
        print(f"已删除项目目录: {BASE_DIR}")
    print("\nClaude Pilot 已完全卸载。")


def main() -> None:
    parser = argparse.ArgumentParser(prog="claude-pilot", description="Claude Pilot v2 管理工具")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("start", help="启动 Bot")
    sub.add_parser("stop", help="停止 Bot")
    sub.add_parser("status", help="查看状态")
    sub.add_parser("enable", help="启用 launchd")
    sub.add_parser("disable", help="禁用 launchd")
    sub.add_parser("logs", help="查看日志")
    sub.add_parser("uninstall", help="完全卸载 Claude Pilot")
    args = parser.parse_args()
    commands = {
        "start": cmd_start, "stop": cmd_stop, "status": cmd_status,
        "enable": cmd_enable, "disable": cmd_disable, "logs": cmd_logs,
        "uninstall": cmd_uninstall,
    }
    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
